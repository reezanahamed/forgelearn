# ForgeLearn configuration — copy to ".env" and edit. All keys are optional;
# every setting below falls back to the default shown in src/forgelearn/config.py.
# Host environment variables OVERRIDE values in .env when both are present.

# --- Server ---
FORGELEARN_HOST=127.0.0.1
FORGELEARN_PORT=8000

# --- Agent engine ---
# Default provider when the browser dropdown doesn't specify one (claude | codex).
FORGELEARN_DEFAULT_AGENT=claude

# Shared by every provider:
# Hard wall-clock timeout for a single agent run, in seconds.
FORGELEARN_AGENT_TIMEOUT_SECONDS=300
# Let the agent write/run code without per-action prompts (local MVP; PLAN §10).
# Each provider maps this to its own bypass flag.
FORGELEARN_AGENT_SKIP_PERMISSIONS=true

# Claude Code (`claude`) provider:
# The actual CLI binary invoked as a subprocess.
FORGELEARN_AGENT_CLI_COMMAND=claude
# Model alias/name to force (blank = let the CLI pick its default).
FORGELEARN_AGENT_MODEL=
# Optional allow-list, e.g. "Write,Edit,Bash" (ignored when skip-permissions is on).
FORGELEARN_AGENT_ALLOWED_TOOLS=
# --bare for reproducible runs; requires API-key auth, so off by default.
FORGELEARN_AGENT_BARE=false

# OpenAI Codex (`codex`) provider (must be installed + authenticated to select it):
# The actual CLI binary invoked as a subprocess.
FORGELEARN_CODEX_CLI_COMMAND=codex
# Model alias/name to force (blank = let the CLI pick its default).
FORGELEARN_CODEX_MODEL=

# --- Orchestrator (Phase 7: the learning method) ---
# Which provider answers the orchestrator's OWN questions (interview, ladder,
# teach-back judging). Blank = reuse FORGELEARN_DEFAULT_AGENT. It need not match the
# provider that BUILDS a project (that one is picked in the browser dropdown).
FORGELEARN_ORCHESTRATOR_AGENT=
# The interview is adaptive: the tutor asks between MIN and MAX questions (only as
# many as needed) to learn the learner's purpose/depth, current level, and time.
FORGELEARN_INTERVIEW_MIN_QUESTIONS=3
FORGELEARN_INTERVIEW_MAX_QUESTIONS=6
# Ladder size bounds — enough rungs to reach the goal, each a short single win.
FORGELEARN_LADDER_MIN_PROJECTS=5
FORGELEARN_LADDER_MAX_PROJECTS=7
# Most probing follow-ups the teach-back gate may raise before it judges.
FORGELEARN_TEACHBACK_MAX_PROBES=3
# Default school grade the AI writes for (plain English). The browser dropdown can
# override it per session; lower = simpler wording.
FORGELEARN_READING_GRADE_DEFAULT=7

# --- Storage / workspaces (relative paths are resolved from the platform root) ---
FORGELEARN_WORKSPACE_DIR=workspaces
FORGELEARN_SESSIONS_DIR=sessions

# --- Workspace Run (Phase 5: execute a built project from the browser) ---
# Hard wall-clock timeout for one Run of a user's project, in seconds.
FORGELEARN_RUN_TIMEOUT_SECONDS=60
# Priority filenames tried first as the Run entrypoint (comma/space-separated);
# falls back to the sole/newest .py file if none match.
FORGELEARN_RUN_ENTRYPOINTS=main.py,app.py
# Byte cap the browser file viewer reads from a workspace file.
FORGELEARN_WORKSPACE_MAX_VIEW_BYTES=200000

# --- Logging ---
FORGELEARN_LOG_LEVEL=INFO

# --- Provider API keys (used from Phase 6 onward; never commit the real .env) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
